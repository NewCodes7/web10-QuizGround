{
  "annotations": { "list": [] },
  "description": "QuizGround nginx 액세스 로그 분석 (Loki)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "요청 현황",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(count_over_time({job=\"nginx\"}[$__range]))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "총 요청 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(count_over_time({job=\"nginx\", status=~\"5..\"}[$__range]))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "5xx 에러 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(count_over_time({job=\"nginx\", status=~\"4..\"}[$__range]))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "4xx 요청 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "unit": "s",
          "noValue": "N/A",
          "decimals": 3
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "avg(avg_over_time({job=\"nginx\"} | json | unwrap request_time | __error__=\"\" [$__range]))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "평균 응답 시간",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "요청률 & 상태",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "3xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(rate({job=\"nginx\", status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(rate({job=\"nginx\", status=~\"3..\"}[$__rate_interval]))",
          "legendFormat": "3xx",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(rate({job=\"nginx\", status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum(rate({job=\"nginx\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ],
      "title": "상태 코드별 요청률",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "sum by (method) (rate({job=\"nginx\"}[$__rate_interval]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "메서드별 요청률",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "응답 시간",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "quantile_over_time(0.50, {job=\"nginx\"} | json | unwrap request_time | __error__=\"\" [$__interval]) by ()",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "quantile_over_time(0.90, {job=\"nginx\"} | json | unwrap request_time | __error__=\"\" [$__interval]) by ()",
          "legendFormat": "P90",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "quantile_over_time(0.95, {job=\"nginx\"} | json | unwrap request_time | __error__=\"\" [$__interval]) by ()",
          "legendFormat": "P95",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "quantile_over_time(0.99, {job=\"nginx\"} | json | unwrap request_time | __error__=\"\" [$__interval]) by ()",
          "legendFormat": "P99",
          "refId": "D"
        }
      ],
      "title": "응답 시간 분위수 (P50/P90/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nginx_connections_active{job=\"nginx\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nginx_connections_reading{job=\"nginx\"}",
          "legendFormat": "reading",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nginx_connections_writing{job=\"nginx\"}",
          "legendFormat": "writing",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nginx_connections_waiting{job=\"nginx\"}",
          "legendFormat": "waiting (keepalive)",
          "refId": "D"
        }
      ],
      "title": "nginx 연결 상태",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 12,
      "title": "Top 요청",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "uri" },
            "properties": [
              { "id": "displayName", "value": "URI" },
              { "id": "custom.width", "value": 400 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "요청 수" },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 13,
      "options": {
        "sortBy": [{ "displayName": "요청 수", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "topk(10, sum by (uri) (count_over_time({job=\"nginx\"} | json | uri != \"\" | __error__=\"\" [$__range])))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 10 URI (요청 수)",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "Value #A", "desc": true }] } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "remote_addr" },
            "properties": [
              { "id": "displayName", "value": "IP" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "요청 수" },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 14,
      "options": {
        "sortBy": [{ "displayName": "요청 수", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "topk(10, sum by (remote_addr) (count_over_time({job=\"nginx\"} | json | remote_addr != \"\" | __error__=\"\" [$__range])))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 10 IP (요청 수)",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "Value #A", "desc": true }] } }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 15,
      "title": "로그",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 16,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "{job=\"nginx\", status=~\"[45]..\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "에러 로그 (4xx / 5xx)",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 43 },
      "id": 17,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_ds}" },
          "expr": "{job=\"nginx\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "전체 액세스 로그",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nginx", "logs", "loki"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "name": "loki_ds",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "QuizGround - nginx 로그",
  "uid": "quizground-nginx-logs",
  "version": 1
}
