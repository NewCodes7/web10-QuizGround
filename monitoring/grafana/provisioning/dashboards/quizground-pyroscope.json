{
  "annotations": { "list": [] },
  "description": "QuizGround 지속 프로파일링 - CPU / 메모리 Flamegraph (Pyroscope)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "CPU 프로파일링",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "description": "이벤트루프 lag spike 구간을 확인한 뒤 대시보드 시간 범위를 해당 구간으로 좁히면 옆 Flamegraph가 그 구간의 프로파일을 보여줍니다.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 20, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
          "expr": "nodejs_eventloop_lag_p99_seconds{job=~\"node.*-app\"} * 1000",
          "legendFormat": "P99 - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
          "expr": "nodejs_eventloop_lag_p50_seconds{job=~\"node.*-app\"} * 1000",
          "legendFormat": "P50 - {{instance}}",
          "refId": "B"
        }
      ],
      "title": "Event Loop Lag (ms) — 구간 확인 후 시간 범위 좁히기",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
      "description": "선택된 시간 범위의 CPU 사용 스택. 넓은 블록일수록 CPU를 많이 소비한 함수입니다. instance 태그로 node1 / node2를 구분할 수 있습니다.",
      "gridPos": { "h": 20, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "minRenderedBlocks": 1 },
      "targets": [
        {
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
          "groupBy": ["instance"],
          "labelSelector": "{service_name=\"quizground.was\"}",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "refId": "A"
        }
      ],
      "title": "CPU Flamegraph (quizground.was)",
      "type": "flamegraph"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 10,
      "title": "메모리 프로파일링",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
      "description": "선택된 시간 범위에서 새로 할당된 메모리 출처. 넓은 블록 = 가장 많은 객체를 생성한 함수. GC 압박 원인 파악에 사용합니다.",
      "gridPos": { "h": 20, "w": 12, "x": 0, "y": 22 },
      "id": 11,
      "options": { "minRenderedBlocks": 1 },
      "targets": [
        {
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
          "groupBy": ["instance"],
          "labelSelector": "{service_name=\"quizground.was\"}",
          "profileTypeId": "memory:alloc_space:bytes:alloc_space:bytes",
          "refId": "A"
        }
      ],
      "title": "메모리 할당 Flamegraph (alloc_space)",
      "type": "flamegraph"
    },
    {
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
      "description": "현재 힙에 남아 있는 메모리 출처. 메모리 누수가 의심될 때 확인합니다.",
      "gridPos": { "h": 20, "w": 12, "x": 12, "y": 22 },
      "id": 12,
      "options": { "minRenderedBlocks": 1 },
      "targets": [
        {
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "${pyroscope_ds}" },
          "groupBy": ["instance"],
          "labelSelector": "{service_name=\"quizground.was\"}",
          "profileTypeId": "memory:inuse_space:bytes:inuse_space:bytes",
          "refId": "A"
        }
      ],
      "title": "메모리 현재 사용 Flamegraph (inuse_space)",
      "type": "flamegraph"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["quizground", "pyroscope", "profiling"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "prometheus_ds",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "pyroscope_ds",
        "options": [],
        "query": "grafana-pyroscope-datasource",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "QuizGround - Pyroscope 프로파일링",
  "uid": "quizground-pyroscope",
  "version": 1
}
