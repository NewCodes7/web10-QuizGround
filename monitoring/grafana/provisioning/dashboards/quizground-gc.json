{
  "annotations": { "list": [] },
  "description": "GC 압박 분석 — pause 분포, 빈도, Buffer 할당 추적, Heap 공간 분해",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["quizground", "gc"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "QuizGround — GC 분석",
  "uid": "quizground-gc",
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "GC 압박 요약",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(nodejs_gc_duration_seconds_sum{job=~\"node.*-app\"}[2m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "GC CPU 점유율 (현재, 정상 < 5%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(nodejs_gc_duration_seconds_bucket{job=~\"node.*-app\"}[1m])) by (le, kind, instance))",
          "legendFormat": "P99 {{kind}} - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(nodejs_gc_duration_seconds_bucket{job=~\"node.*-app\"}[1m])) by (le, kind, instance))",
          "legendFormat": "P95 {{kind}} - {{instance}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(nodejs_gc_duration_seconds_bucket{job=~\"node.*-app\"}[1m])) by (le, kind, instance))",
          "legendFormat": "P50 {{kind}} - {{instance}}",
          "refId": "C"
        }
      ],
      "title": "GC Pause 분포 — P50 / P95 / P99 (kind별)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "할당 패턴 — 객체 수명 추론",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(nodejs_gc_duration_seconds_count{job=~\"node.*-app\"}[1m])",
          "legendFormat": "{{kind}} - {{instance}}",
          "refId": "A"
        }
      ],
      "description": "minor(Scavenge) 빈도 높음 = short-lived 객체 대량 생성. major(MarkSweep) 빈도 높음 = 구세대 메모리 압박.",
      "title": "GC 발생 빈도 (events/s, kind별)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_external_memory_bytes{job=~\"node.*-app\"}",
          "legendFormat": "External (Buffer) - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_heap_size_used_bytes{job=~\"node.*-app\"}",
          "legendFormat": "Heap Used - {{instance}}",
          "refId": "B"
        }
      ],
      "description": "External Memory = Buffer.from() 등 off-heap 할당량. 부하 중 증가 후 GC로 회수되면 Buffer가 주 GC 원인.",
      "title": "External Memory (Buffer off-heap) vs Heap Used",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Heap 공간 분해",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_heap_space_size_used_bytes{job=~\"node.*-app\", space=~\"new_space|old_space|large_object_space|code_space\"}",
          "legendFormat": "{{space}} - {{instance}}",
          "refId": "A"
        }
      ],
      "description": "new_space(Young Gen) 높음 = short-lived 객체 많음. old_space 높음 = 장기 생존 객체 누적. large_object_space 높음 = 큰 Buffer 객체.",
      "title": "Heap Space 사용량 (new / old / large_object / code)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=~\"node.*-app\"}[30s]) * 1000",
          "legendFormat": "GC pause rate (ms/s) - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_eventloop_lag_p99_seconds{job=~\"node.*-app\"} * 1000",
          "legendFormat": "EL Lag P99 (ms) - {{instance}}",
          "refId": "B"
        }
      ],
      "description": "GC spike와 Event Loop Lag spike가 겹치면 stop-the-world GC가 응답 지연의 직접 원인.",
      "title": "GC Pause rate vs Event Loop Lag P99",
      "type": "timeseries"
    }
  ]
}
